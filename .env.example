# Copy this file to .env and fill in the values.
# Never commit your real .env.

# Discord bot token
DISCORD_TOKEN=your_discord_bot_token_here

# (Optional) Web panel port
PORT=3000

# (Optional) WebUI auth
WEBUI_REQUIRE_AUTH=true
WEBUI_LOGIN_USERNAME=admin
WEBUI_LOGIN_PASSWORD=change_me
WEBUI_SESSION_SECRET=change_me_too

# (Optional) Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# One-off scripts
GUILD_ID=
